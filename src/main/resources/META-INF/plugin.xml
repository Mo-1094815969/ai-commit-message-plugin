<idea-plugin>
    <id>com.github.aicommit.message.generator</id>
    <name>AI Commit Message Generator</name>
    <vendor>Mo</vendor>

    <resource-bundle>messages.AiCommitBundle</resource-bundle>

    <description><![CDATA[
        <p>Generate Git commit messages from selected files in the JetBrains Commit tool window.</p>
        <p>Supports Claude and Codex/OpenAI-compatible relays, read-only cc-switch configuration, environment fallback, and provider-specific local Skills.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.github.aicommit.settings.AiCommitSettings"/>
        <applicationConfigurable
                instance="com.github.aicommit.settings.AiCommitConfigurable"
                id="ai.commit.settings"
                displayName="AI Commit Message / AI 提交信息"/>
        <notificationGroup id="AI Commit Message Notifications" displayType="BALLOON"/>
    </extensions>

    <actions>
        <action id="AiCommit.GenerateCommitMessageAction"
                class="com.github.aicommit.action.GenerateCommitMessageAction"
                text="AI Generate Commit Message"
                description="Generate commit message from selected files using AI"
                icon="/icons/ai-commit.svg">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
